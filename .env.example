# UKG Pro WFM MCP Server Configuration
# Copy to .env and fill with your tenant values.

# Base URL for your WFM tenant (default shown)
UKG_WFM_BASE_URL=https://api.ultipro.com/workforce/v1

# Tenant identifier (if required by your gateway)
UKG_WFM_TENANT_ID=your-tenant-code

# Preferred: Provide a long-lived bearer token for service integration (demo / testing)
UKG_WFM_BEARER_TOKEN=your-oauth-bearer-token-here

# Production OAuth2 client credentials (recommended)
UKG_WFM_CLIENT_ID=your-client-id
UKG_WFM_CLIENT_SECRET=your-client-secret
UKG_WFM_TOKEN_URL=https://api.ultipro.com/oauth2/token
UKG_WFM_SCOPE=wfm

# Optional: path to full OpenAPI yaml/json for production ingest
# UKG_WFM_OPENAPI_PATH=/path/to/ukg-pro-wfm-openapi.yml

# Logging
LOG_LEVEL=info
